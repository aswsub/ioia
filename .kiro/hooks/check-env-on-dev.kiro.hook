{
  "enabled": true,
  "name": "Check Environment on Dev Start",
  "description": "Automatically checks if required environment variables are set when the dev server starts, and provides guidance if they're missing",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The user reported a blank screen when running npm run dev. This is likely due to missing Supabase environment variables. Please check if VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are configured in the .env file. If they're missing, guide the user on how to set them up. The app needs these credentials to initialize authentication properly."
  }
}