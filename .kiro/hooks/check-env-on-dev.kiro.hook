{
  "enabled": true,
  "name": "Check Demo Environment",
  "description": "When a developer asks about running the app locally, Kiro checks for the environment variables that commonly cause blank auth screens, failed Claude calls, or broken Gmail OAuth redirects.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "If the user is trying to run ioia locally or reports a blank screen, failed draft generation, failed login, or Gmail OAuth errors, inspect .env without printing secrets. Verify the presence of VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, ANTHROPIC_API_KEY, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI, GOOGLE_TOKEN_ENCRYPTION_KEY, and APP_BASE_URL as relevant. Explain which values are browser-exposed VITE values and which must remain server-only. For local development, remind the user to run npm run dev for Vite and npm run dev:api for the API backend when testing /api/google routes. Never echo secret values."
  }
}
